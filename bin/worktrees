#!/usr/bin/env bash
# ─── worktrees ───────────────────────────────────────────────────────────────
# Create and manage isolated git worktrees under .worktrees/<slug>, each opened in
# its own tmux session (pane 0 your AI CLI, pane 1 shell). Works in ANY git repo —
# it finds the repo via git, namespaces tmux sessions by repo, and auto-detects
# the package manager for the install pane.
#
#   worktrees new <branch> [base]         # create a worktree + tmux (AI | shell)
#   worktrees new <branch> --name <topic> # ...named independently of the branch
#   worktrees co  <branch>                # checkout a REMOTE branch (fetch if needed)
#   worktrees switch [<worktree>] <branch> [base]  # move a worktree to another branch
#   worktrees open <name>                 # reopen an existing worktree's tmux session
#   worktrees ls [--json]                 # list worktrees + state (--json = machine-readable, schema v1)
#   worktrees rm  <name> [name...]        # tear one (or more) down
#   worktrees -V | --version              # print version   (also: help / -h)
#   worktrees                             # (no args) → ls
#
# A worktree is a PLACE (dir, tmux session + AI CLI history, node_modules); a
# branch is a unit of work that flows through it. The place is named after its
# first branch unless --name says otherwise; `switch` moves it to the next branch
# without touching anything expensive. Omit <worktree> when already cd'd inside one.
#
# `new`/`co`/`switch` are do-what-I-mean: reuse an existing worktree, check out
# an existing local OR remote branch (fetching it first), or create a new branch
# off <base> (default main). The shell pane runs the detected install
# (pnpm/npm/yarn/bun).
#
# new/co/open OPTIONS:  -r/--resume   (append the AI CLI's resume flag, default -r)
#                       --ai <cmd>    (AI pane command for this run)  --no-attach
# new/co also:          --no-install  --no-tmux  --no-fetch  --name <topic>
# switch OPTIONS:       --force (switch despite uncommitted changes)  --no-fetch  -y/--yes
# rm OPTIONS:           --branch (delete branch too)  --force  -y/--yes
#
# Pane 0 runs your AI CLI through an interactive shell so a shell alias resolves.
# Pick the command with --ai, $WORKTREES_AI_CMD, or `ai_cmd` in
# ~/.config/worktrees/config (default `claude`; set it to `none` for a plain
# shell). -r appends $WORKTREES_AI_RESUME_ARG / `ai_resume_arg` (default `-r`).
#
# Naming: tmux session = <prefix>-<slug>, where <prefix> is $WORKTREES_PREFIX,
# else a .worktree-prefix file at the repo root, else `prefix` in the user
# config, else the repo's directory name. This keeps sessions from different
# repos from colliding.
# ────────────────────────────────────────────────────────────────────────────
# shellcheck disable=SC2016  # single-quoted $SHELL in tmux pane commands is intentional (expand at pane start, not here)
# shellcheck disable=SC2015  # `A && B || C` used deliberately where C is the "else" of a test, never a fallthrough risk
# shellcheck disable=SC2001  # `sed 's/^/    /'` indents multi-line vars; ${var//} can't anchor per-line
set -euo pipefail

WORKTREES_VERSION="0.1.0"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; DIM='\033[2m'; NC='\033[0m'
info()  { echo -e "${GREEN}▸${NC} $1"; }
warn()  { echo -e "${YELLOW}▸${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1" >&2; }
header(){ echo -e "\n${CYAN}═══ $1 ═══${NC}"; }
usage() { awk 'NR==1{next} /^# shellcheck/{exit} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0"; }

# help/version must work anywhere (fresh machine, outside any repo) — handle
# them BEFORE the git guards below.
case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
  -V|--version)   echo "worktrees $WORKTREES_VERSION"; exit 0 ;;
esac

command -v git >/dev/null 2>&1 || { error "git not found"; exit 1; }
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { error "Not inside a git repository."; exit 1; }
# --git-common-dir is shared by all worktrees and lives in the MAIN repo's .git,
# so this resolves the main checkout whether run from main or another worktree.
# pwd -P (physical): `git worktree list --porcelain` prints realpath'd paths, so
# a repo reached through a symlink (macOS /var → /private/var, a symlinked
# ~/workspace) would otherwise never match wt_registered and everything would
# look "stale".
GIT_COMMON="$(cd "$(git rev-parse --git-common-dir)" && pwd -P)"
MAIN_ROOT="$(cd "$GIT_COMMON/.." && pwd -P)"
WT_ROOT="$MAIN_ROOT/.worktrees"

# ── user config ──────────────────────────────────────────────────────────────
# ~/.config/worktrees/config (respects $XDG_CONFIG_HOME): `key = value` lines,
# `#` comments. Parsed with sed — NEVER sourced (config is data, not code).
# Keys: ai_cmd, ai_resume_arg, prefix.
WT_CONFIG_FILE="${XDG_CONFIG_HOME:-${HOME:-}/.config}/worktrees/config"
cfg_get() {   # last matching key wins; empty when absent; inline `# …` stripped
  [[ -f "$WT_CONFIG_FILE" ]] || return 0
  sed -n "s/^[[:space:]]*$1[[:space:]]*=[[:space:]]*//p" "$WT_CONFIG_FILE" \
    | sed -e 's/[[:space:]]#.*$//' -e 's/[[:space:]]*$//' | tail -n 1 || true
}

# AI pane command, resolved flag > env > user config > default `claude`.
# $WORKTREES_CLAUDE_CMD is honored as a deprecated alias of $WORKTREES_AI_CMD.
# Empty or `none` → pane 0 is a plain shell.
resolve_ai_cmd() {
  local flag="${1:-}" v
  if [[ -n "$flag" ]]; then v="$flag"
  elif [[ -n "${WORKTREES_AI_CMD:-}" ]]; then v="$WORKTREES_AI_CMD"
  elif [[ -n "${WORKTREES_CLAUDE_CMD:-}" ]]; then v="$WORKTREES_CLAUDE_CMD"
  else v="$(cfg_get ai_cmd)"; [[ -n "$v" ]] || v="claude"
  fi
  [[ "$v" == none ]] && v=""
  printf '%s' "$v"
}
resolve_ai_resume_arg() {
  local v="${WORKTREES_AI_RESUME_ARG:-}"
  [[ -n "$v" ]] || v="$(cfg_get ai_resume_arg)"
  [[ -n "$v" ]] || v="-r"
  printf '%s' "$v"
}

# Namespace prefix → keeps sessions from different repos from colliding.
# $WORKTREES_PREFIX > committed .worktree-prefix file > user config > repo dir name.
PREFIX="${WORKTREES_PREFIX:-}"
[[ -n "$PREFIX" ]] || PREFIX="$(head -n 1 "$MAIN_ROOT/.worktree-prefix" 2>/dev/null | tr -d '[:space:]' || true)"
[[ -n "$PREFIX" ]] || PREFIX="$(cfg_get prefix)"
PREFIX="${PREFIX:-$(basename "$MAIN_ROOT")}"
PREFIX="$(printf '%s' "$PREFIX" | LC_ALL=C tr '[:upper:]' '[:lower:]' | LC_ALL=C tr -c 'a-z0-9_-' '-')"

wt_session() { local s="${PREFIX}-${1}"; echo "${s//./-}"; }   # tmux dislikes '.'
# Does session $1 exist, EXACTLY? tmux -t targets prefix-match (so `has-session
# -t repo-api` is true when only repo-api-fix exists) — an exact check keeps
# `rm api` from killing api-fix's session and ls/open from matching siblings.
session_exists() { tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -qxF "$1"; }
# Name of an existing tmux session that already lives in worktree dir $1 (a pane
# cwd'd there) — so `open` reuses an AI pane already running under any session
# name instead of spawning a second one. Prefers a pane that looks like the
# configured AI CLI ($2 = its first word); wrappers (npx, aliases) resolve to
# other process names, so this heuristic degrades gracefully to `best=`.
worktree_session() {
  local wt="$1" ai_word="${2:-claude}" sess path cmd best=""
  command -v tmux >/dev/null 2>&1 || return 0
  while IFS=$'\t' read -r sess path cmd; do
    [[ -n "$sess" && ( "$path" == "$wt" || "$path" == "$wt"/* ) ]] || continue
    case "$cmd" in *"$ai_word"*|node) echo "$sess"; return 0 ;; esac
    [[ -z "$best" ]] && best="$sess"
  done < <(tmux list-panes -a -F '#{session_name}'$'\t''#{pane_current_path}'$'\t''#{pane_current_command}' 2>/dev/null || true)
  [[ -n "$best" ]] && echo "$best" || true
}
# Is $1 a REGISTERED worktree? A stale unregistered dir under .worktrees/ is a
# trap: `git -C` inside it resolves UPWARD to the main checkout, so any git
# operation "on the worktree" would actually hit the main repo. Always gate.
wt_registered() { git -C "$MAIN_ROOT" worktree list --porcelain 2>/dev/null | grep -qxF "worktree $1"; }
# Dir of the .worktrees/ worktree currently ON branch $1 (empty if none) — lets
# branch-based lookups find the place after `switch` moved it to a new branch.
wt_for_branch() {
  git -C "$MAIN_ROOT" worktree list --porcelain 2>/dev/null | awk -v root="$WT_ROOT/" -v b="refs/heads/$1" '
    /^worktree /{wt=substr($0,10)} /^branch /{if (substr($0,8)==b && index(wt,root)==1) {print wt; exit}}' || true
}
wt_dirty() { git -C "$1" status --porcelain 2>/dev/null; }
# Branch of worktree $1 for display/branch-ops: "(detached)" when HEAD is
# detached (rev-parse prints the literal "HEAD" then).
wt_branch() {
  local b; b="$(git -C "$1" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
  [[ "$b" == HEAD ]] && b="(detached)"
  printf '%s' "$b"
}

# Default base for a NEW branch: main, else master, else the repo's current HEAD.
default_base() {
  local cand
  for cand in main master; do
    if git -C "$MAIN_ROOT" show-ref --verify -q "refs/heads/$cand" || git -C "$MAIN_ROOT" show-ref --verify -q "refs/remotes/origin/$cand"; then echo "$cand"; return; fi
  done
  git -C "$MAIN_ROOT" symbolic-ref --short HEAD 2>/dev/null || echo main
}

# Package manager to run in the shell pane, from the worktree's lockfile (empty = none).
detect_install_cmd() {
  local d="$1"
  [[ -f "$d/pnpm-lock.yaml" ]]                         && { echo "pnpm install"; return; }
  [[ -f "$d/bun.lockb" || -f "$d/bun.lock" ]]          && { echo "bun install";  return; }
  [[ -f "$d/yarn.lock" ]]                              && { echo "yarn";         return; }
  [[ -f "$d/package-lock.json" || -f "$d/npm-shrinkwrap.json" ]] && { echo "npm install"; return; }
  echo ""
}

# Make sure .worktrees/ is ignored in THIS repo (local, untracked).
ensure_excluded() {
  local excl="$GIT_COMMON/info/exclude" p='.worktrees/'
  [[ -e "$excl" ]] || : > "$excl" 2>/dev/null || return 0
  git -C "$MAIN_ROOT" check-ignore -q "$p" 2>/dev/null && return 0   # already ignored
  grep -qxF "$p" "$excl" 2>/dev/null && return 0
  echo "$p" >> "$excl"
}

# Single-quote $1 for safe embedding in a shell -c/-ic string ('… '\'' …' idiom).
# NOTE: pane 0 hands this to the USER's $SHELL — assumes a POSIX-ish shell
# (bash/zsh/sh). fish parses plain single-quoted strings fine but not the
# embedded-quote idiom; documented limitation.
# (Replacement routed through a variable: backslash semantics of ${var//pat/rep}
# replacement text changed in bash 4 — the inline form breaks on 3.2.)
sq() { local q="'\''"; printf "'%s'" "${1//\'/$q}"; }

# (re)open a worktree's tmux session — pane 0 AI CLI, pane 1 shell — then attach.
# $1=worktree dir  $2=session name  $3=install command for the shell pane ("" = none)
# $4=AI pane command ("" = plain shell). Honors the DO_ATTACH global.
launch_tmux() {
  local WT="$1" SESSION="$2" install_cmd="${3:-}" ai_cmd="${4:-}"
  local KEEP='exec "${SHELL:-/bin/sh}"' PANE0_CMD PANE1_CMD P0
  local ai_word="${ai_cmd%% *}"; ai_word="$(basename "${ai_word:-claude}")"
  # Reuse a session already living in this worktree — the named one, or any other
  # session whose pane is cwd'd here (e.g. an AI pane started under a different
  # name) — instead of spawning a second one. (session_exists, not has-session:
  # tmux -t prefix-matches sibling names.)
  if ! session_exists "$SESSION"; then
    local existing; existing="$(worktree_session "$WT" "$ai_word")"
    [[ -n "$existing" ]] && SESSION="$existing"
  fi
  if session_exists "$SESSION"; then
    warn "tmux session '$SESSION' already in this worktree — attaching."
  else
    header "Opening tmux session '$SESSION'"
    # Launch each pane's program as its start command (tmux runs it via `sh -c`) —
    # robust, unlike send-keys which races the shell's startup. `exec "$SHELL"`
    # keeps the pane a live interactive shell once the program exits.
    # Pane 0 runs the AI launcher through an INTERACTIVE shell ($SHELL -ic)
    # so a shell alias (e.g. `cl`) resolves — tmux's own `sh -c` won't load your
    # rc. The command is single-quote-escaped: a launcher containing quotes or
    # spaces must not break out of the -ic string.
    if [[ -n "$ai_cmd" ]]; then
      PANE0_CMD="exec \"\${SHELL:-/bin/sh}\" -ic $(sq "${ai_cmd}; ${KEEP}")"
    else
      PANE0_CMD="exec \"\${SHELL:-/bin/sh}\""
    fi
    if [[ -n "$install_cmd" ]]; then
      PANE1_CMD="$install_cmd && echo '✓ deps ready'; $KEEP"
    else
      PANE1_CMD="$KEEP"
    fi
    P0="$(tmux new-session -d -s "$SESSION" -c "$WT" -P -F '#{pane_id}' "$PANE0_CMD")"
    tmux split-window -h -t "$P0" -c "$WT" "$PANE1_CMD" >/dev/null
    tmux select-pane -t "$P0"
  fi
  if [[ "${DO_ATTACH:-true}" == false ]]; then
    info "Session ready (detached). Attach with: tmux attach -t $SESSION"; return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then tmux switch-client -t "$SESSION"; else tmux attach -t "$SESSION"; fi
}

# Move registered worktree $1 to branch $2 (base $3, fetch $4, force $5).
# DWIM: local branch → switch; unfetched remote → fetch + track; neither → new
# branch off base. Dirty-guarded. The place (session/deps) is untouched.
do_switch() {
  local WT="$1" branch="$2" base="${3:-}" do_fetch="${4:-true}" force="${5:-false}"
  local cur; cur="$(wt_branch "$WT")"
  if [[ "$cur" == "$branch" ]]; then info "Already on '$branch' — nothing to do."; return 0; fi

  local dirty; dirty="$(wt_dirty "$WT" || true)"
  if [[ -n "$dirty" && "$force" != true ]]; then
    warn "Worktree '$(basename "$WT")' has uncommitted changes:"; echo "$dirty" | sed 's/^/    /'
    error "Refusing to switch. Commit/stash, or pass --force (git will still refuse on conflicts)."
    return 1
  fi

  switch_fail() {
    error "git switch failed. If the branch is checked out in another worktree:"
    git -C "$MAIN_ROOT" worktree list | sed 's/^/    /'
    return 1
  }
  if git -C "$MAIN_ROOT" show-ref --verify --quiet "refs/heads/$branch"; then
    info "Branch exists locally — switching."
    git -C "$WT" switch "$branch" || { switch_fail; return 1; }
  else
    if [[ "$do_fetch" == true ]] && ! git -C "$MAIN_ROOT" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
      info "Fetching origin/${branch}..."
      git -C "$MAIN_ROOT" fetch --quiet origin "refs/heads/$branch:refs/remotes/origin/$branch" 2>/dev/null || true
    fi
    if git -C "$MAIN_ROOT" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
      info "Tracking remote branch origin/$branch."
      git -C "$WT" switch "$branch" || { switch_fail; return 1; }   # git DWIM creates the tracking branch
    else
      [[ -z "$base" ]] && base="$(default_base)"
      [[ "$do_fetch" == true ]] && git -C "$MAIN_ROOT" fetch --quiet origin "$base" 2>/dev/null || true
      local START="$base"
      git -C "$MAIN_ROOT" show-ref --verify --quiet "refs/remotes/origin/$base" && START="origin/$base"
      info "Creating new branch '$branch' off '$START'."
      git -C "$WT" switch -c "$branch" "$START" || { switch_fail; return 1; }
    fi
  fi
  info "was '$cur' → now '$branch'. Session and deps untouched — keep working."
}

# ── new / co — create a worktree (or checkout a local/remote branch) ─────────
cmd_new() {
  local DO_INSTALL=true DO_TMUX=true DO_ATTACH=true DO_FETCH=true RESUME=false BRANCH="" BASE="" NAME="" AI_FLAG="" expect=""
  for arg in "$@"; do
    if [[ -n "$expect" ]]; then
      # A flag here means the value was forgotten — swallowing it would mint an
      # unaddressable '--flag'-named worktree (rm/open/switch all reject dashes).
      [[ "$arg" == -* ]] && { error "--$expect needs a value (got '$arg')"; exit 1; }
      case "$expect" in name) NAME="$arg" ;; ai) AI_FLAG="$arg" ;; esac
      expect=""; continue
    fi
    case "$arg" in
      --no-install) DO_INSTALL=false ;;
      --no-tmux)    DO_TMUX=false ;;
      --no-attach)  DO_ATTACH=false ;;
      --no-fetch)   DO_FETCH=false ;;
      -r|--resume)  RESUME=true ;;
      --name)       expect=name ;;
      --name=*)     NAME="${arg#--name=}" ;;
      --ai)         expect=ai ;;
      --ai=*)       AI_FLAG="${arg#--ai=}" ;;
      -*) error "Unknown flag: $arg"; exit 1 ;;
      *)  if [[ -z "$BRANCH" ]]; then BRANCH="$arg"; elif [[ -z "$BASE" ]]; then BASE="$arg"; else error "Too many args: $arg"; exit 1; fi ;;
    esac
  done
  [[ -z "$expect" ]] || { error "--$expect needs a value"; exit 1; }
  [[ -n "$BRANCH" ]] || { error "Branch name required.  e.g. worktrees new feat/foo"; exit 1; }
  BRANCH="${BRANCH#origin/}"            # accept origin/feat/x → feat/x
  [[ -z "$BASE" ]] && BASE="$(default_base)"
  if [[ "$DO_TMUX" == true ]] && ! command -v tmux >/dev/null 2>&1; then
    warn "tmux not found — continuing with --no-tmux"; DO_TMUX=false
  fi

  # The worktree is a PLACE (dir, session); the branch is its first content.
  # --name names the place independently (topic workspaces, e.g. "messaging");
  # default stays the branch name — right for the one-shot case.
  local SLUG="${NAME:-$BRANCH}"; SLUG="${SLUG//\//-}"
  local WT="$WT_ROOT/$SLUG"

  # Branch→place redirect: after a `switch`, a branch may live in a worktree
  # whose name doesn't match it. Creating a second checkout would fatal
  # ("already checked out") — reuse the place that holds the branch instead.
  if [[ ! -e "$WT" ]]; then
    local holder; holder="$(wt_for_branch "$BRANCH")"
    if [[ -n "$holder" ]]; then
      if [[ -n "$NAME" ]]; then
        error "Branch '$BRANCH' is already checked out in worktree '$(basename "$holder")' — can't also put it in '$SLUG'."
        error "Use: worktrees open $(basename "$holder")   (or switch that worktree off the branch first)"
        exit 1
      fi
      SLUG="$(basename "$holder")"; WT="$holder"
      info "Branch '$BRANCH' already lives in worktree '$SLUG' — using that."
    fi
  fi

  local SESSION; SESSION="$(wt_session "$SLUG")"
  ensure_excluded

  header "Worktree for '$BRANCH'"
  info "repo: $MAIN_ROOT  (prefix: $PREFIX)"
  info "dir : $WT"

  local ALREADY=false
  if wt_registered "$WT"; then
    ALREADY=true
    # The place may sit on a different branch (switch/--name broke slug==branch).
    # Never attach claiming a branch the worktree isn't on — switch or fail loud.
    local cur; cur="$(wt_branch "$WT")"
    if [[ "$cur" == "$BRANCH" ]]; then
      warn "Worktree already exists on '$BRANCH' — reusing it (skipping create/install)."
    else
      warn "Worktree '$SLUG' exists but is on '$cur' — switching to '$BRANCH'."
      do_switch "$WT" "$BRANCH" "$BASE" "$DO_FETCH" false || exit 1
    fi
  elif [[ -e "$WT" ]]; then
    error "$WT exists but is not a registered worktree. Remove it or pick another branch."; exit 1
  elif git -C "$MAIN_ROOT" show-ref --verify --quiet "refs/heads/$BRANCH"; then
    info "Branch '$BRANCH' exists locally — checking it out."
    git -C "$MAIN_ROOT" worktree add "$WT" "$BRANCH"
  else
    # Not local. Make sure we know about the remote branch (fetch if allowed), then
    # track it. This is the "checkout a remote branch" path.
    if [[ "$DO_FETCH" == true ]] && ! git -C "$MAIN_ROOT" show-ref --verify --quiet "refs/remotes/origin/$BRANCH"; then
      info "Fetching origin/${BRANCH}..."
      git -C "$MAIN_ROOT" fetch --quiet origin "refs/heads/$BRANCH:refs/remotes/origin/$BRANCH" 2>/dev/null || true
    fi
    if git -C "$MAIN_ROOT" show-ref --verify --quiet "refs/remotes/origin/$BRANCH"; then
      info "Checking out remote branch origin/$BRANCH (tracking)."
      git -C "$MAIN_ROOT" worktree add --track -b "$BRANCH" "$WT" "origin/$BRANCH"
    else
      [[ "$DO_FETCH" == true ]] && git -C "$MAIN_ROOT" fetch --quiet origin "$BASE" 2>/dev/null || true
      local START="$BASE"
      git -C "$MAIN_ROOT" show-ref --verify --quiet "refs/remotes/origin/$BASE" && START="origin/$BASE"
      info "Creating new branch '$BRANCH' off '$START'."
      git -C "$MAIN_ROOT" worktree add -b "$BRANCH" "$WT" "$START"
    fi
  fi

  local install_cmd=""
  [[ "$DO_INSTALL" == true && "$ALREADY" == false ]] && install_cmd="$(detect_install_cmd "$WT")"
  local ai_cmd; ai_cmd="$(resolve_ai_cmd "$AI_FLAG")"
  [[ "$RESUME" == true && -n "$ai_cmd" ]] && ai_cmd="$ai_cmd $(resolve_ai_resume_arg)"

  if [[ "$DO_TMUX" == false ]]; then
    header "Done (no tmux)"
    info "cd $WT"
    [[ -n "$install_cmd" ]] && info "then: $install_cmd"
    return 0
  fi
  launch_tmux "$WT" "$SESSION" "$install_cmd" "$ai_cmd"
}

# ── switch — move an existing worktree (place) to its next branch ───────────
# The place keeps everything expensive — tmux session + AI CLI history,
# node_modules. Only the checked-out branch changes. DWIM like co: existing
# local → switch; remote → fetch + track; neither → new branch off [base]
# (default main).
cmd_switch() {
  local args=() FORCE=false DO_FETCH=true YES=false a
  for a in "$@"; do
    case "$a" in
      --force)    FORCE=true ;;
      --no-fetch) DO_FETCH=false ;;
      -y|--yes)   YES=true ;;
      -*) error "Unknown flag: $a"; exit 1 ;;
      *) args+=("$a") ;;
    esac
  done

  # Which worktree am I standing in (empty if none)? Physical pwd — WT_ROOT is
  # realpath'd, a symlinked cwd would never match the logical $PWD.
  local cwd_topic="" phys_pwd; phys_pwd="$(pwd -P)"
  [[ "$phys_pwd" == "$WT_ROOT"/* ]] && { cwd_topic="${phys_pwd#"$WT_ROOT"/}"; cwd_topic="${cwd_topic%%/*}"; }

  # Arg shapes:  switch <worktree> <branch> [base]   |   switch <branch> [base]  (inside a worktree)
  # First arg counts as a worktree name iff that worktree exists.
  local topic="" branch="" base=""
  if [[ ${#args[@]} -ge 2 && -d "$WT_ROOT/${args[0]//\//-}" ]]; then
    topic="${args[0]//\//-}"; branch="${args[1]}"; base="${args[2]:-}"
    [[ ${#args[@]} -le 3 ]] || { error "Too many args."; exit 1; }
    # Ambiguity guard: standing in worktree A while args target worktree B could
    # ALSO read as "switch A to branch B" — confirm before touching another place.
    if [[ -n "$cwd_topic" && "$topic" != "$cwd_topic" && "$YES" != true ]]; then
      warn "You're inside '$cwd_topic' but this targets worktree '$topic' (branch '$branch')."
      read -r -p "Switch '$topic'? [y/N] " ans || ans=""   # EOF (piped stdin) = abort, not silent set -e death
      [[ "$ans" =~ ^[Yy]$ ]] || { info "Aborted."; return 0; }
    fi
  else
    if [[ -n "$cwd_topic" ]]; then
      topic="$cwd_topic"
      # Typo guard: 2 args here means args[0] was NOT a worktree name and is being
      # reinterpreted as the branch — say so, so `switch mesaging main` can't
      # silently mint a junk branch named after a typo.
      [[ ${#args[@]} -ge 2 ]] && warn "No worktree '${args[0]}' — treating args as <branch> <base> for '$topic' (from cwd)."
    elif [[ ${#args[@]} -ge 2 ]]; then
      error "No worktree '${args[0]}' under .worktrees/. See: worktrees ls"; exit 1
    else
      error "Not inside a worktree — name one: worktrees switch <worktree> <branch>"; exit 1
    fi
    branch="${args[0]:-}"; base="${args[1]:-}"
    [[ ${#args[@]} -le 2 ]] || { error "Too many args."; exit 1; }
  fi
  [[ -n "$branch" ]] || { error "switch needs a branch.  e.g. worktrees switch messaging feat/next"; exit 1; }
  branch="${branch#origin/}"
  local WT="$WT_ROOT/$topic"

  # Registration gate — a stale UNREGISTERED dir under .worktrees/ would make
  # every `git -C` resolve upward to the MAIN checkout and switch THAT instead.
  wt_registered "$WT" || { error "'$topic' exists but is not a registered worktree — refusing (a switch would hit the main checkout). Clean it up: worktrees rm $topic"; exit 1; }

  header "Switching '$topic' → '$branch'"
  do_switch "$WT" "$branch" "$base" "$DO_FETCH" "$FORCE"
}

# ── open — (re)attach an existing worktree's tmux session (AI | shell) ──────
cmd_open() {
  local name="" a RESUME=false AI_FLAG="" expect=""; DO_ATTACH=true
  for a in "$@"; do
    if [[ -n "$expect" ]]; then
      [[ "$a" == -* ]] && { error "--ai needs a value (got '$a')"; exit 1; }
      AI_FLAG="$a"; expect=""; continue
    fi
    case "$a" in
      --no-attach)  DO_ATTACH=false ;;
      -r|--resume)  RESUME=true ;;
      --ai)         expect=ai ;;
      --ai=*)       AI_FLAG="${a#--ai=}" ;;
      -*) error "Unknown flag: $a"; exit 1 ;;
      *) [[ -z "$name" ]] && name="$a" || { error "Too many args: $a"; exit 1; } ;;
    esac
  done
  [[ -z "$expect" ]] || { error "--ai needs a value"; exit 1; }
  [[ -n "$name" ]] || { error "open needs a worktree (slug or branch). See: worktrees ls"; exit 1; }
  command -v tmux >/dev/null 2>&1 || { error "tmux not found"; exit 1; }
  local slug="${name//\//-}"
  local WT="$WT_ROOT/$slug"
  if [[ ! -d "$WT" ]]; then
    # Not a place name — maybe a BRANCH living in a differently-named place.
    local holder; holder="$(wt_for_branch "${name#origin/}")"
    [[ -n "$holder" ]] || { error "No worktree '$slug' under .worktrees/.  Create it: worktrees new $name"; exit 1; }
    slug="$(basename "$holder")"; WT="$holder"
    info "Branch '$name' lives in worktree '$slug' — opening that."
  fi
  local SESSION; SESSION="$(wt_session "$slug")"
  local ai_cmd; ai_cmd="$(resolve_ai_cmd "$AI_FLAG")"
  [[ "$RESUME" == true && -n "$ai_cmd" ]] && ai_cmd="$ai_cmd $(resolve_ai_resume_arg)"
  launch_tmux "$WT" "$SESSION" "" "$ai_cmd"
}

# Creation + last-commit timestamps for `ls`. stat/date flags differ BSD(macOS)
# vs GNU(Linux). Probing the GNU spelling once is safer than try-and-fallback
# per call: GNU `date -r` means "mtime of FILE" and GNU `stat -f` means
# "filesystem status", so a stray file named like an epoch (or `%B`) could make
# the BSD spelling *succeed wrongly* on Linux.
STAT_STYLE=bsd; stat -c '%Y' / >/dev/null 2>&1 && STAT_STYLE=gnu
DATE_STYLE=bsd; [[ "$(date -u -d @0 +%Y 2>/dev/null || true)" == 1970 ]] && DATE_STYLE=gnu   # -u: GNU renders @0 in LOCAL time (1969 west of UTC) without it
stat_birth() {   # birth (creation) epoch of a path; falls back to mtime if unknown
  local b
  if [[ "$STAT_STYLE" == bsd ]]; then
    stat -f '%B' "$1" 2>/dev/null || echo 0
  else
    b="$(stat -c '%W' "$1" 2>/dev/null || echo 0)"                      # GNU: 0 = unsupported
    [[ "$b" == 0 ]] && b="$(stat -c '%Y' "$1" 2>/dev/null || echo 0)"   # → mtime
    echo "$b"
  fi
}
fmt_date() {     # epoch → YYYY-MM-DD ("-" if unknown; ASCII so %-Ns pads by column)
  [[ "${1:-0}" -gt 0 ]] 2>/dev/null || { echo "-"; return; }
  if [[ "$DATE_STYLE" == bsd ]]; then date -r "$1" +%F 2>/dev/null || echo "-"
  else date -d "@$1" +%F 2>/dev/null || echo "-"; fi
}
ago() {          # epoch → compact age vs $NOW (e.g. 3h, 5d, 2w)
  local s=$(( NOW - ${1:-0} )); (( s < 0 )) && s=0
  if   (( s < 3600 ));   then echo "$(( s/60 ))m"
  elif (( s < 86400 ));  then echo "$(( s/3600 ))h"
  elif (( s < 604800 )); then echo "$(( s/86400 ))d"
  else                        echo "$(( s/604800 ))w"; fi
}

fit() { local s="$1" w="$2"; (( ${#s} > w )) && s="${s:0:w-1}~"; printf '%s' "$s"; }  # truncate to width w (~ marks a cut)

# ── JSON output (schema_version 1) ─────────────────────────────────────────────
# Machine-readable `ls --json`, for the UI (and any consumer). Emitted by a path
# SEPARATE from the human `ls` so the table stays byte-for-byte identical (its
# bats assertions must not move). No jq — strings are escaped in pure bash, the
# same zero-runtime-deps discipline the config uses. Everything here is READ-ONLY,
# derived live from git/tmux exactly like cmd_ls.
WT_SCHEMA_VERSION=1

# JSON-escape $1 → a quoted scalar. Escapes backslash, quote, and the common
# control chars; any remaining C0 byte (0x00-0x1F) → '?' via awk (a raw control
# byte otherwise makes the whole document invalid JSON and blanks the UI).
# Replacement literals route through vars: bash 3.2's ${v//pat/repl} mangles a
# backslash-bearing inline replacement (the same reason sq() does it).
json_str() {
  # shellcheck disable=SC1003  # '\"' etc. are literal JSON escapes, not mis-escaped quotes
  local s=${1-} dq='\"' tb='\t' nl='\n' cr='\r' ff='\f'
  # Backslash first, via sed — portable across bash 3.2 AND 5.x. A pure-bash
  # \\-doubling is NOT portable: 3.2 keeps ${//} replacement backslashes literal,
  # but 5.x reprocesses them (\\ → \), leaving a lone \ that invalidates the JSON.
  # Fast-path: only fork sed when a backslash is actually present (usually none).
  case $s in *\\*) s=$(printf '%s' "$s" | sed 's/\\/\\\\/g') ;; esac
  s=${s//\"/$dq}
  s=${s//$'\t'/$tb}; s=${s//$'\n'/$nl}; s=${s//$'\r'/$cr}; s=${s//$'\f'/$ff}
  case $s in
    *[$'\001'-$'\010'$'\013'$'\016'-$'\037']*)
      s=$(printf '%s' "$s" | LC_ALL=C awk '{gsub(/[\001-\010\013\016-\037]/,"?");print}') ;;
  esac
  printf '"%s"' "$s"
}
json_bool() { [[ "${1-}" == true ]] && printf true || printf false; }
json_nn()   { [[ "${1-}" =~ ^-?[0-9]+$ ]] && printf '%s' "$1" || printf null; }   # int or null

# Upstream tracking ref of worktree $1 (empty if none).
wt_upstream()     { git -C "$1" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true; }
# "<behind>\t<ahead>" vs @{u} (empty when there's no upstream). Net-new — no
# existing helper computed divergence.
wt_ahead_behind() { git -C "$1" rev-list --left-right --count '@{u}...HEAD' 2>/dev/null || true; }

# Claude Code stores per-project session logs under ~/.claude/projects/<mangled>,
# the project's ABSOLUTE path with every '/' and '.' turned into '-'. This mapping
# is OBSERVED, not documented — a mismatch degrades to false, never an error.
# Honors $HOME (so test isolation reports false cleanly).
claude_dir_for()     { printf '%s/.claude/projects/%s' "${HOME:-}" "$(printf '%s' "$1" | LC_ALL=C sed 's#[/.]#-#g')"; }
claude_has_session() { local d="$1" f; [[ -n "$d" && -d "$d" ]] || return 1; for f in "$d"/*.jsonl; do [[ -e "$f" ]] && return 0; done; return 1; }

# One place → one JSON object (schema v1). $1=dir  $2=is_main (true/false). Reuses
# the same derived-state helpers as cmd_ls; unknowable fields are explicit null so
# a consumer deserializes a fixed shape. A stale UNREGISTERED dir emits a minimal
# object (registered:false) — never run branch/dirty git ops in it (they'd read MAIN).
emit_place_json() {
  local d="$1" is_main="${2:-false}" slug session cdir cpresent=false tmux_up=false bepoch created life
  if [[ "$is_main" == true ]]; then slug='(main)'; else slug="$(basename "$d")"; fi
  session="$(wt_session "$slug")"; session_exists "$session" && tmux_up=true
  cdir="$(claude_dir_for "$d")"; claude_has_session "$cdir" && cpresent=true
  bepoch="$(stat_birth "$d")"; created="$(fmt_date "$bepoch")"
  life=closed; [[ "$tmux_up" == true ]] && life=active   # P0: no declared store yet → live-only

  if [[ "$is_main" != true ]] && ! wt_registered "$d"; then
    printf '{"schema_version":%s,"slug":%s,"path":%s,"is_main":false,"registered":false,' \
      "$WT_SCHEMA_VERSION" "$(json_str "$slug")" "$(json_str "$d")"
    printf '"branch":null,"detached":null,"dirty":null,"dirty_files":null,"ahead":null,"behind":null,"upstream":null,'
    printf '"created":%s,"created_epoch":%s,"last_commit_epoch":null,"last_commit_subject":null,' \
      "$(json_str "$created")" "$(json_nn "$bepoch")"
    printf '"tmux_session":{"name":%s,"up":%s},' "$(json_str "$session")" "$(json_bool "$tmux_up")"
    printf '"claude_session_present":%s,"claude_session_dir":%s,' "$(json_bool "$cpresent")" "$(json_str "$cdir")"
    printf '"install_cmd":null,"stack":null,"declared":null,"lifecycle_effective":%s}' "$(json_str "$life")"
    return 0
  fi

  local raw branch detached dirtytext dirty dirty_files upstream ab behind ahead cepoch csubj install
  raw="$(git -C "$d" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
  if [[ -z "$raw" || "$raw" == HEAD ]]; then detached=true; branch=''; else detached=false; branch="$raw"; fi
  dirtytext="$(wt_dirty "$d" || true)"
  if [[ -n "$dirtytext" ]]; then dirty=true; dirty_files="$(printf '%s\n' "$dirtytext" | grep -c .)"; else dirty=false; dirty_files=0; fi
  upstream="$(wt_upstream "$d")"
  ab="$(wt_ahead_behind "$d")"; behind=''; ahead=''
  [[ -n "$ab" ]] && read -r behind ahead <<<"$ab"
  cepoch="$(git -C "$d" log -1 --format=%ct 2>/dev/null || echo 0)"
  csubj="$(git -C "$d" log -1 --format=%s 2>/dev/null || true)"
  install="$(detect_install_cmd "$d")"

  printf '{"schema_version":%s,"slug":%s,"path":%s,"is_main":%s,"registered":true,' \
    "$WT_SCHEMA_VERSION" "$(json_str "$slug")" "$(json_str "$d")" "$(json_bool "$is_main")"
  if [[ "$detached" == true ]]; then printf '"branch":null,"detached":true,'; else printf '"branch":%s,"detached":false,' "$(json_str "$branch")"; fi
  printf '"dirty":%s,"dirty_files":%s,' "$(json_bool "$dirty")" "$(json_nn "$dirty_files")"
  printf '"ahead":%s,"behind":%s,' "$(json_nn "$ahead")" "$(json_nn "$behind")"
  if [[ -n "$upstream" ]]; then printf '"upstream":%s,' "$(json_str "$upstream")"; else printf '"upstream":null,'; fi
  printf '"created":%s,"created_epoch":%s,' "$(json_str "$created")" "$(json_nn "$bepoch")"
  if [[ "${cepoch:-0}" -gt 0 ]] 2>/dev/null; then printf '"last_commit_epoch":%s,' "$(json_nn "$cepoch")"; else printf '"last_commit_epoch":null,'; fi
  if [[ -n "$csubj" ]]; then printf '"last_commit_subject":%s,' "$(json_str "$csubj")"; else printf '"last_commit_subject":null,'; fi
  printf '"tmux_session":{"name":%s,"up":%s},' "$(json_str "$session")" "$(json_bool "$tmux_up")"
  printf '"claude_session_present":%s,"claude_session_dir":%s,' "$(json_bool "$cpresent")" "$(json_str "$cdir")"
  if [[ -n "$install" ]]; then printf '"install_cmd":%s,' "$(json_str "$install")"; else printf '"install_cmd":null,'; fi
  printf '"stack":null,"declared":null,"lifecycle_effective":%s}' "$(json_str "$life")"
}

# `ls --json` — full snapshot: main place FIRST, then each .worktrees/* in the
# SAME last-commit-recency order the human ls uses (stable; ties keep glob order).
emit_ls_json() {
  printf '{"schema_version":%s,"repo":%s,"prefix":%s,"places_file":%s,"places":[' \
    "$WT_SCHEMA_VERSION" "$(json_str "$MAIN_ROOT")" "$(json_str "$PREFIX")" "$(json_str "$MAIN_ROOT/.worktrees.places.json")"
  emit_place_json "$MAIN_ROOT" true
  if [[ -d "$WT_ROOT" ]]; then
    shopt -s nullglob; local dirs=("$WT_ROOT"/*/); shopt -u nullglob
    if [[ ${#dirs[@]} -gt 0 ]]; then
      local key d
      while IFS=$'\t' read -r key d; do
        [[ -n "$d" ]] || continue
        printf ','; emit_place_json "$d" false
      done < <(
        for wd in "${dirs[@]}"; do
          wd="${wd%/}"; bep="$(stat_birth "$wd")"
          if wt_registered "$wd"; then cep="$(git -C "$wd" log -1 --format=%ct 2>/dev/null || echo 0)"; else cep=0; fi
          k="$cep"; [[ "${k:-0}" -gt 0 ]] 2>/dev/null || k="${bep:-0}"
          printf '%s\t%s\n' "${k:-0}" "$wd"
        done | sort -s -t$'\t' -k1,1 -rn
      )
    fi
  fi
  printf ']}\n'
}

# ── ls ───────────────────────────────────────────────────────────────────────
cmd_ls() {
  local a
  for a in "$@"; do case "$a" in --json) emit_ls_json; return 0 ;; esac; done
  [[ "${WORKTREES_JSON:-}" == 1 ]] && { emit_ls_json; return 0; }
  [[ -d "$WT_ROOT" ]] || { info "No worktrees (.worktrees/ is empty)."; return 0; }
  shopt -s nullglob; local dirs=("$WT_ROOT"/*/); shopt -u nullglob
  [[ ${#dirs[@]} -gt 0 ]] || { info "No worktrees (.worktrees/ is empty)."; return 0; }
  local NOW; NOW="$(date +%s)"

  # Pass 1: gather each row's fields and measure the two variable-width columns
  # (SLUG, BRANCH). Fixed-width printf alone can't win here — a single long name
  # overflows its column and shoves every later column out of alignment (the
  # "cluttered" bug). Padding to the measured max keeps the grid straight.
  # Cell placeholders must stay ASCII: a multibyte char under-pads %-Ns.
  local -a R_slug R_btext R_bcol R_created R_age R_tmux R_git R_key
  local maxslug=4 maxbranch=6   # header labels "SLUG"/"BRANCH" are the floor
  local d slug bepoch created branch cepoch age btext bcol tmux_s gitd key
  for d in "${dirs[@]}"; do
    d="${d%/}"; slug="$(basename "$d")"
    bepoch="$(stat_birth "$d")"; created="$(fmt_date "$bepoch")"
    if ! wt_registered "$d"; then
      # Stale unregistered dir: `git -C` here would read the MAIN checkout —
      # don't report main's branch/dirt as if they were this dir's.
      btext="(rm $slug)"; bcol="$YELLOW"
      R_slug+=("$slug"); R_btext+=("$btext"); R_bcol+=("$bcol")
      R_created+=("$created"); R_age+=("-")
      R_tmux+=("○"); R_git+=("${YELLOW}stale${NC}")
      R_key+=("${bepoch:-0}")   # no commit to read — sort by creation
    else
      branch="$(wt_branch "$d")"; [[ -n "$branch" ]] || branch="?"
      cepoch="$(git -C "$d" log -1 --format=%ct 2>/dev/null || echo 0)"
      if [[ "${cepoch:-0}" -gt 0 ]] 2>/dev/null; then age="$(ago "$cepoch")"; else age="-"; fi
      # tint the branch cyan when it diverges from the slug — the place≠branch signal
      btext="$branch"; bcol=""; [[ "${branch//\//-}" != "$slug" ]] && bcol="$CYAN"
      tmux_s="○"; gitd="clean"
      session_exists "$(wt_session "$slug")" && tmux_s="${GREEN}●${NC}"
      [[ -n "$(wt_dirty "$d")" ]] && gitd="${YELLOW}dirty${NC}"
      R_slug+=("$slug"); R_btext+=("$btext"); R_bcol+=("$bcol")
      R_created+=("$created"); R_age+=("$age")
      R_tmux+=("$tmux_s"); R_git+=("$gitd")
      # sort by last-commit recency; fall back to creation when no commit read
      key="$cepoch"; [[ "${key:-0}" -gt 0 ]] 2>/dev/null || key="${bepoch:-0}"
      R_key+=("${key:-0}")
    fi
    (( ${#slug}  > maxslug   )) && maxslug=${#slug}
    (( ${#btext} > maxbranch )) && maxbranch=${#btext}
  done
  (( maxslug   > 44 )) && maxslug=44      # ceiling so one pathological name
  (( maxbranch > 44 )) && maxbranch=44    # can't blow the whole row width out

  # Default order: most recently active (last commit) on top. Sort row indices by
  # their epoch key descending; ties keep discovery (glob) order via stable -s.
  # (while-read fill, NOT the bash-4 array-fill builtin — must run on bash 3.2.)
  local -a order; order=()
  local i
  while IFS= read -r i; do order+=("$i"); done < <(
    for i in "${!R_key[@]}"; do printf '%s\t%s\n' "${R_key[$i]}" "$i"; done \
      | sort -s -rn -k1,1 | cut -f2
  )

  # Pass 2: print, padding SLUG/BRANCH to the measured widths (pad the PLAIN text
  # first, then wrap color — escape codes must not count toward column width).
  printf "${DIM}%-*s  %-*s  %-10s  %-5s  %-4s %s${NC}\n" "$maxslug" SLUG "$maxbranch" BRANCH CREATED COMMIT TMUX GIT
  local bpad
  for i in "${order[@]}"; do
    printf -v bpad '%-*s' "$maxbranch" "$(fit "${R_btext[$i]}" "$maxbranch")"
    [[ -n "${R_bcol[$i]}" ]] && bpad="${R_bcol[$i]}${bpad}${NC}"
    printf "%-*s  %b  %-10s  %-5s  %b   %b\n" \
      "$maxslug" "$(fit "${R_slug[$i]}" "$maxslug")" "$bpad" \
      "${R_created[$i]}" "${R_age[$i]}" \
      "${R_tmux[$i]}" "${R_git[$i]}"
  done
  echo -e "${DIM}● session live · ${CYAN}branch${NC}${DIM} ≠ name · COMMIT = age of last commit.  open <slug> · switch <slug> <branch> · rm <slug>${NC}"
}

# ── rm ─────────────────────────────────────────────────────────────────────
remove_one() {
  local name="$1" slug path branch session dirty
  slug="${name//\//-}"; path="$WT_ROOT/$slug"
  # rm's own guard refuses '..' as a final component, but don't rely on it.
  case "$slug" in ''|.|..) error "Invalid worktree name '$name'."; return 1 ;; esac
  [[ -d "$path" ]] || { error "No worktree '$slug' under .worktrees/ (looked for $path)"; return 1; }
  [[ "$(pwd -P)" == "$path"* ]] && { error "You're inside $slug — cd elsewhere first."; return 1; }

  # A stale UNREGISTERED dir needs different handling: `git -C` inside it reads
  # the MAIN checkout (wrong branch/dirt), and `git worktree remove` refuses it.
  local reg=true; wt_registered "$path" || reg=false
  if [[ "$reg" == true ]]; then
    branch="$(wt_branch "$path")"
    [[ "$branch" == "(detached)" ]] && branch=""   # no branch ops on a detached HEAD
    dirty="$(wt_dirty "$path" || true)"
  else
    branch=""; dirty=""
    warn "'$slug' is not a registered worktree (stale dir) — will plain-delete it."
  fi
  session="$(wt_session "$slug")"

  if [[ -n "$dirty" && "$FORCE" != true ]]; then
    warn "Worktree '$slug' has uncommitted changes:"; echo "$dirty" | sed 's/^/    /'
    error "Refusing to remove. Commit/stash, or pass --force."; return 1
  fi

  if [[ "$YES" != true ]]; then
    echo -e "Remove ${CYAN}$slug${NC} → tmux ${YELLOW}$session${NC} · worktree dir$( [[ "$DEL_BRANCH" == true && -n "$branch" ]] && echo " · branch ${YELLOW}$branch${NC}" )"
    read -r -p "Proceed? [y/N] " ans || ans=""   # EOF (piped stdin) = skip, not silent set -e death
    [[ "$ans" =~ ^[Yy]$ ]] || { info "Skipped $slug."; return 0; }
  fi

  # Exact-name gate before kill: `-t` prefix-matches, so killing "repo-api"
  # blindly would take out a live "repo-api-fix" session.
  if session_exists "$session"; then
    tmux kill-session -t "=$session" 2>/dev/null || tmux kill-session -t "$session" 2>/dev/null || true
    info "killed tmux $session"
  fi
  if [[ "$reg" == true ]]; then
    git -C "$MAIN_ROOT" worktree remove --force "$path" && info "removed worktree $slug"
  else
    rm -rf "$path" && info "deleted stale dir $slug"
  fi
  git -C "$MAIN_ROOT" worktree prune

  if [[ "$DEL_BRANCH" == true && -n "$branch" ]]; then
    local flag="-d"; [[ "$FORCE" == true ]] && flag="-D"
    if git -C "$MAIN_ROOT" branch "$flag" "$branch" 2>/dev/null; then info "deleted branch $branch"
    else warn "branch '$branch' not deleted (unmerged? use --force to force)"; fi
  elif [[ -n "$branch" ]]; then
    # (elif, not `[[ … ]] &&` — a trailing false test would make a SUCCESSFUL
    # branchless removal return 1.)
    info "kept branch $branch (use --branch to delete)"
  fi
}

cmd_rm() {
  local names=(); DEL_BRANCH=false; FORCE=false; YES=false
  for a in "$@"; do
    case "$a" in
      --branch) DEL_BRANCH=true ;;
      --force)  FORCE=true ;;
      -y|--yes) YES=true ;;
      -*) error "Unknown flag: $a"; exit 1 ;;
      *) names+=("$a") ;;
    esac
  done
  [[ ${#names[@]} -gt 0 ]] || { error "rm needs a worktree name (slug or branch). See: worktrees ls"; exit 1; }
  local rc=0 n
  for n in "${names[@]}"; do header "Removing $n"; remove_one "$n" || rc=1; done
  return $rc
}

# ── dispatch ─────────────────────────────────────────────────────────────────
SUB="${1:-ls}"; shift || true
case "$SUB" in
  new|create)           cmd_new "$@" ;;
  co|checkout)          cmd_new "$@" ;;
  switch|sw|branch)     cmd_switch "$@" ;;
  open|reopen|attach|a) cmd_open "$@" ;;
  ls|list)              cmd_ls "$@" ;;
  rm|remove|delete)     cmd_rm "$@" ;;
  *) error "Unknown command: $SUB"; echo; usage; exit 1 ;;
esac
