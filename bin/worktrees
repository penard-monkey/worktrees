#!/usr/bin/env bash
# worktrees — run the compiled Rust CLI from a clone (the shipped engine, see
# MIGRATION.md). Prefers a release build, else debug. `make install` symlinks the
# built binary directly onto your PATH; this shim is for running from the repo
# and is the bats WT_BIN target (a shebang SCRIPT, not the binary, so
# `bash "$WT_BIN"` works with zero harness edits). The legacy bash engine lives
# at bin/worktrees.bash (a parallel gate until the migration completes).
here="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
for b in "$here/target/release/worktrees" "$here/target/debug/worktrees"; do
  if [ -x "$b" ]; then exec "$b" "$@"; fi
done
echo "worktrees: compiled binary not found — build it with: cargo build --release -p worktrees-cli" >&2
exit 127
